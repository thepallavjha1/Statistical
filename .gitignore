# .gitignore - Exclude files from git

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb

# Database
*.db
*.sqlite
*.sqlite3
data/*.parquet
data/*.csv
!config/*.csv

# Logs
logs/
*.log

# Environment variables
.env
.env.local
.env.*.local

# Streamlit
.streamlit/secrets.toml

# Testing
.pytest_cache/
.coverage
htmlcov/

# OS
.DS_Store
Thumbs.db

# Temporary files
tmp/
temp/
*.tmp

# Docker volumes
postgres_data/

# Cache
.cache/
*.cache
